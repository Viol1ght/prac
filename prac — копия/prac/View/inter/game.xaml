<Window x:Class="prac.View.inter.game"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:prac.View.inter"
        mc:Ignorable="d"
        Title="intr" Height="750" Width="1200"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
         Background="Transparent">

    <Window.Resources>
        <Style x:Key="trigBth" TargetType="Button" >
            <Setter Property="Background" Value="#88eaf7"/>
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Padding" Value="10,5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="3"
                                Width="300" Height="50">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Blue"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="#88eaf7"
                    CornerRadius="20,0,0,20">
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Ava" Width="100" Height="100" 
                                        Background="White"
                                        CornerRadius="100"/>
                        <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">

                            <TextBlock Text="{Binding UserNek}" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"
                                               Foreground="White"/>
                            <TextBlock Text="{Binding UserName}" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"
                                               Foreground="White"/>
                        </StackPanel>
                    </Grid>
                    <Button Style="{StaticResource trigBth}"
                                    x:Name="Shop"
                                    FontFamily="Century Gothic"
                                    FontSize="16" 
                                    HorizontalAlignment="Left"
                                    Margin="0 80 0 0" Click="maga_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/telega2.jpg"
                                   Width="30" Height="30"
                                   Margin="10,0,10,0"/>
                            <TextBlock Text="Магазин" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource trigBth}"
                             x:Name="dok"
                             FontFamily="Century Gothic"
                             FontSize="16"
                             HorizontalAlignment="Left"
                             Margin="0 0 0 0" Click="bymaga_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/nomen.jpg"
                                   Width="30" Height="30"
                                   HorizontalAlignment="Left"
                                   Margin="10,0,10,0" />
                            <TextBlock Text="Номеклатура" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource trigBth}"
                            x:Name="Game"
                            FontFamily="Century Gothic"
                            FontSize="16" Background="#64b2bd"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 0" Click="game_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/gamepade.png"
                                    Width="30" Height="30"
                                    HorizontalAlignment="Left"
                                    Margin="10,0,10,0" />
                            <TextBlock Text="Игры" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource trigBth}"
                            x:Name="set"
                            FontFamily="Century Gothic"
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 0" Click="set_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/set2.jpg"
                                    Width="30" Height="30"
                                    Margin="10,0,10,0" />
                            <TextBlock Text="Настройки аккаунта" FontFamily="Century Gothic"
                                   FontWeight="ExtraLight" TextWrapping="Wrap"
                                   FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource trigBth}" 
            x:Name="bthBask" 
            FontFamily="Century Gothic" 
            FontSize="16" 
            HorizontalAlignment="Left" 
            Margin="0 0 0 0" Click="bthBask_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/corzina.jpg" 
                   Width="30" Height="30" 
                   Margin="10 0 10 0"/>
                            <TextBlock Text="Корзина" FontFamily="Century Gothic"  
                   FontWeight="ExtraLight" TextWrapping="Wrap" 
                   FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Border>
            <Grid Grid.Column="1">
                <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="-" FontSize="20"
                            Width="30" Margin="5,5,5,5"
                            Background="LightBlue" Foreground="White"
                            Click="btnMin_click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Content="0" FontSize="20"
                            Width="30" Height="30" Margin="5"
                            Background="DarkGoldenrod" Foreground="White"
                            Click="btnMax_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="X" FontSize="20"
                            Width="30" Margin="5,0,5,5"
                            Background="#FF9D140A" Foreground="White"
                            Click="btnClose_click" Height="30" VerticalAlignment="Bottom">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>

                <ScrollViewer Width="600" HorizontalAlignment="Left" Background="Gray">
                    <WrapPanel Width="Auto">
                        <Border Background="White" Width="150" Height="200"
                                       Margin="10 50 0 0" CornerRadius="10">
                            <StackPanel>
                                <Border x:Name="IMG1" Width="130" Height="130" Background="Gray"
                                    CornerRadius="10" HorizontalAlignment="Center"
                                    Margin="0 10 0 0" VerticalAlignment="Top"/>

                                <TextBlock Text="Текст" FontFamily="Century Gothic"
                                                  FontWeight="ExtraLight" TextWrapping="Wrap"
                                                  FontSize="15"/>
                                <ToggleButton Width="94" Height="30"
                                                     Background="Transparent"
                                                     BorderThickness="0" Checked="LikeButton_Cheched">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border Background="Blue" CornerRadius="5">
                                                <TextBlock x:Name="Heart" HorizontalAlignment="Center"
                                                       Text="Купить"
                                                       FontSize="24"
                                                       Foreground="Wheat" Margin="0,-1,0,-1"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Heart" Property="Foreground" Value="RosyBrown"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="Heart" Property="Foreground" Value="Wheat"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </StackPanel>
                        </Border>

                    </WrapPanel>

                </ScrollViewer>
                <Grid Width="300" Height="58" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,592">
                    <Border Height="48" Width="300" HorizontalAlignment="Center" VerticalAlignment="Top"
                            CornerRadius="10 0 0 10" Background="#88eaf7">
                        <Grid x:Name="search" HorizontalAlignment="Center" Width="200">

                            <TextBox x:Name="Poisk" VerticalAlignment="Center"  Height="30" FontSize="15" FontFamily="Century Gothic" Margin="0,0,-31,0"  />
                        </Grid>
                    </Border>
                    <Image Source="/View/img/lypa.jpg"
                                       Margin="10,5,254,13"/>
                    <Button x:Name="btnPoisk" Height="40" Width="40" HorizontalAlignment="Left"
                                    Background="Transparent" Margin="10,5,0,13" Click="btnPoisk_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Grid Width="300" HorizontalAlignment="Center" Margin="0,80,0,-590">
                        <StackPanel Background="#88eaf7">
                            <TextBlock Text="Фильтры" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" Foreground="White" 
                                       FontSize="20" VerticalAlignment="Center" />
                            <Button Width="200" Height="25" Margin="0 10 0 0" Content="Шутер"
                                    Foreground="Black" FontSize="15" Click="Button_Click"/>
                            <Button Width="200" Height="25" Margin="0 10 0 0" Content="Инди"
                                    Foreground="Black" FontSize="15" Click="Button_Click_1"/>
                            <Button Width="200" Height="25" Margin="0 10 0 0" Content="Хоррор"
                                    Foreground="Black" FontSize="15" Click="Button_Click_2"/>
                            <Button Width="200" Height="25" Margin="0 10 0 0" Content="DLS"
                                    Foreground="Black" FontSize="15" Click="Button_Click_3"/>
                            <Button Width="200" Height="25" Margin="0 10 0 0" Content="Атмосферная"
                                    Foreground="Black" FontSize="15" Click="Button_Click_4"/>

                        </StackPanel>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
