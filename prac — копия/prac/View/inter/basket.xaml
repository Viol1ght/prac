<Window x:Class="prac.View.inter.basket" 
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
        xmlns:local="clr-namespace:prac.View.inter" 
        mc:Ignorable="d" 
        Title="Bask" Height="750" Width="1200" 
        WindowStyle="None" WindowStartupLocation="CenterScreen"  
        Background="Transparent">

    <Window.Resources>
        <Style x:Key="TrigBth" TargetType="Button">
            <Setter Property="Background" Value="#88eaf7"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10 5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"  
                                BorderThickness="0"  
                                CornerRadius="3" 
                                Width="300" Height="50">
                            <ContentPresenter HorizontalAlignment="Left"  
                                              VerticalAlignment="Center"  
                                              Margin="10 0 0 0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF1E3A8A"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0" 
                Background="#88eaf7" 
                CornerRadius="20 0 0 20">
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Ava"  Width="100" Height="100" 
                            Background="White" 
                            CornerRadius="100"/>

                        <StackPanel Grid.Column="1" 
                                Margin="10 0 0 0" 
                                VerticalAlignment="Center">

                            <TextBlock Text="{Binding UserNek}" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20" 
                                       Foreground="White"/>
                            <TextBlock Text="{Binding UserName}" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"  
                                       Foreground="White"/>

                        </StackPanel>
                    </Grid>
                    <Button Style="{StaticResource TrigBth}" 
                                x:Name="Shop" 
                                FontFamily="Century Gothic" 
                                FontSize="16" 
                                HorizontalAlignment="Left" 
                                Margin="0 80 0 0" Click="Shop_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/telega2.jpg" 
                                       Width="30" Height="30" 
                                       Margin="10 0 10 0"/>
                            <TextBlock Text="Магазин" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" 
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TrigBth}" 
                                x:Name="Dok" 
                                FontFamily="Century Gothic" 
                                FontSize="16" 
                                HorizontalAlignment="Left" 
                                Margin="0 0 0 0" Click="Dok_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/nomen.jpg" 
                                       Width="30" Height="30" 
                                       Margin="10 0 10 0"/>
                            <TextBlock Text="Номенклатура" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" 
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TrigBth}" 
                                x:Name="Game" 
                                FontFamily="Century Gothic" 
                                FontSize="16" 
                                HorizontalAlignment="Left" 
                                Margin="0 0 0 0" Click="Game_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/gamepade.png" 
                                       Width="30" Height="30" 
                                       Margin="10 0 10 0"/>
                            <TextBlock Text="Игры" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" 
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource TrigBth}" 
                                x:Name="Set" 
                                FontFamily="Century Gothic" 
                                FontSize="16" 
                                HorizontalAlignment="Left" 
                                Margin="0 0 0 0" Click="Set_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/set2.jpg" 
                                       Width="30" Height="30" 
                                       Margin="10 0 10 0"/>
                            <TextBlock Text="Настройки аккаунта" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" 
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource TrigBth}" 
                                x:Name="bthBask" 
                                FontFamily="Century Gothic" 
                                FontSize="16" Background="#64b2bd" 
                                HorizontalAlignment="Left" 
                                Margin="0 0 0 0" Click="bthBask_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/corzina.jpg" 
                                       Width="30" Height="30" 
                                       Margin="10 0 10 0"/>
                            <TextBlock Text="Корзина" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" 
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>


                </StackPanel>

            </Border>
            <Grid Grid.Column="1">
                <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="-" FontSize="20" 
                        Width="30" Height="30" Margin="5" 
                        Background="#FF567FCB" Foreground="White" 
                        Click="btnMin_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Content="O" FontSize="20" 
                        Width="30" Height="30" Margin="5" 
                        Background="DarkGoldenrod" Foreground="White" 
                        Click="btnMax_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="X" FontSize="20" 
                        Width="30" Height="30" Margin="5" 
                        Background="#FF9D140A" Foreground="White" 
                        Click="btnClose_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="5" 
                                    BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center" 
                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>


                <ListBox ScrollViewer.VerticalScrollBarVisibility="Auto" Width="auto" 
Margin="0 10 254 0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>

                    <ListBoxItem>
                        <Border Background="#FFF0F0F0" Margin="5" Padding="5" 
CornerRadius="10" >
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <CheckBox x:Name="chekSelect" VerticalAlignment="Center" 
Margin="5" Checked="chekSelect_Checked"/>
                                <Border Grid.Column="1" Width="50" Height="50"  
                                Background="Gray" CornerRadius="5"/>
                                <TextBlock Grid.Column="2" x:Name="NameTov" Text="Название 
товара" 
                               VerticalAlignment="Center" FontSize="16" Margin="0 0 8 0"/>
                                <Button Grid.Column="3" x:Name="bthMin" Content="-" Width="25" 
Height="25" Margin="5" 
                                    Background="Bisque" FontSize="20" Click="bthMin_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="5" 
                                                BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock Grid.Column="4" x:Name="QuantText" Text="1" 
VerticalAlignment="Center"/>
                                <Button Grid.Column="5" x:Name="bthMax" Content="+" Width="25" 
Height="25" Margin="5"         
                                    Background="Bisque" FontSize="20" Click="bthMax_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="5" 
                                            BorderThickness="0">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <TextBlock Grid.Column="6" x:Name="SumText" Text="100 ₽" 
                                   VerticalAlignment="Center" Margin="10 0 0 0"/>

                            </Grid>
                        </Border>
                    </ListBoxItem>
                </ListBox>
                <Grid Width="250" Height="auto" VerticalAlignment="Bottom" 
HorizontalAlignment="Right">
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"  
                                Width="250" Height="auto">

                        <Border Background="#88eaf7" Width="250" Height="auto" 
CornerRadius="15 0 20 0">

                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <CheckBox x:Name="SelectAll" 
                                          Content="Выбрать все" 
                                          Foreground="White" 
                                          FontSize="16" 
                                          Margin="5" Checked="SelectAll_Checked"/>
                                <StackPanel Grid.Row="1" Margin="0 20 0 0">
                                    <Button x:Name="DelTov" Content="Удалить" 
                                            Height="40" 
                                            Margin="0 0 0 10" 
                                            Background="#FF80423E" 
                                            Foreground="White" FontSize="20" Click="DelTov_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="15" 
                                                BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                    <Button x:Name="bthArrange" Content="Оформить заказ" 
                                            Height="40" 
                                            Background="#FF383A4A" 
                                            Foreground="White" FontSize="20" Click="bthArrange_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" 
                                                CornerRadius="15" 
                                                BorderThickness="0">
                                                    <ContentPresenter HorizontalAlignment="Center" 
                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>

                                <Grid Grid.Row="2"/>
                                <StackPanel Grid.Row="3" Margin="0 10 0 0">
                                    <TextBlock Text="Итого:" 
                                               Foreground="White" 
                                               FontSize="18"/>

                                    <TextBlock x:Name="TotalSum" 
                                               Text="0 ₽" 
                                               Foreground="#FF34D466" 
                                               FontSize="22" 
                                               FontWeight="Bold"/>
                                </StackPanel>
                            </Grid>

                        </Border>

                    </StackPanel>
                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>