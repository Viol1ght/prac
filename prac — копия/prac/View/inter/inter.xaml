<Window x:Class="prac.View.inter.inter"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:prac.View.inter"
        mc:Ignorable="d"
        Title="intr" Height="750" Width="1200"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
         Background="Transparent">

    <Window.Resources>
        <Style x:Key="trigBth" TargetType="Button" >
            <Setter Property="Background" Value="#FF0B1F5E"/>
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Padding" Value="10,5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="3"
                                Width="300" Height="50">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Blue"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="#FF0B1F5E"
                    CornerRadius="20,0,0,20">
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Ava" Width="100" Height="100" 
                                        Background="White"
                                        CornerRadius="100"/>
                        <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">

                            <TextBlock Text="{Binding UserNek}" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"
                                               Foreground="White"/>
                            <TextBlock Text="{Binding UserName}" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"
                                               Foreground="White"/>

                        </StackPanel>
                    </Grid>
                    <Button Style="{StaticResource trigBth}"
                                    x:Name="Shop"
                                    FontFamily="Century Gothic"
                                    FontSize="16"
                                    HorizontalAlignment="Left"
                                    Margin="0 80 0 0" Click="Shop_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/photo_2026-04-02_00-28-11.jpg"
                                   Width="30" Height="30"
                                   Margin="10,0,10,0"/>
                            <TextBlock Text="Магазин" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource trigBth}"
                             x:Name="dok"
                             FontFamily="Century Gothic"
                             FontSize="16"
                             HorizontalAlignment="Left"
                             Margin="0 0 0 0" Click="dok_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/photo_2026-04-02_20-37-35.jpg"
                                   Width="30" Height="30"
                                   HorizontalAlignment="Left"
                                   Margin="10,0,10,0" />
                            <TextBlock Text="Номеклатура" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource trigBth}"
                            x:Name="Game"
                            FontFamily="Century Gothic"
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 0" Click="Game_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/photo_2026-04-02_20-27-17.jpg"
                                    Width="30" Height="30"
                                    HorizontalAlignment="Left"
                                    Margin="10,0,10,0" />
                            <TextBlock Text="Игры" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource trigBth}"
                            x:Name="Set"
                            FontFamily="Century Gothic"
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 0" Click="Set_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/photo_2026-04-02_20-27-26.jpg"
                                    Width="30" Height="30"
                                    Margin="10,0,10,0" />
                            <TextBlock Text="Настройки аккаунта" FontFamily="Century Gothic"
                                   FontWeight="ExtraLight" TextWrapping="Wrap"
                                   FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>


                </StackPanel>

            </Border>
            <Grid Grid.Column="1">
                <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="-" FontSize="20"
                            Width="30" Margin="5,5,5,5"
                            Background="LightBlue" Foreground="White"
                            Click="btnMin_click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Content="0" FontSize="20"
                            Width="30" Margin="5,5,5,2"
                            Background="DarkGoldenrod" Foreground="White"
                            Click="btnMax_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="X" FontSize="20"
                            Width="30" Margin="5,5,5,2"
                            Background="#FF9D140A" Foreground="White"
                            Click="btnClose_click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>


                <ScrollViewer Width="600" HorizontalAlignment="Left">
                    <WrapPanel Width="Auto">
                        <Border Background="#FF8A8A8A" Width="150" Height="200"
                                       Margin="10 50 0 0" CornerRadius="10">
                            <StackPanel>
                                <Border x:Name="IMG" Width="130" Height="130" Background="White"
                                    CornerRadius="10" HorizontalAlignment="Center"
                                    Margin="0 10 0 0" VerticalAlignment="Top"/>

                                <TextBlock Text="Текст" FontFamily="Century Gothic"
                                                  FontWeight="ExtraLight" TextWrapping="Wrap"
                                                  FontSize="15"/>

                                <ToggleButton Width="30" Height="30"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Bottom"
                                                     Margin="0 0 10 10"
                                                     Background="Transparent"
                                                     BorderThickness="0" Checked="LikeButton_Cheched">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="Transparent">
                                                <TextBlock x:Name="Heart"
                                                       Text="❤"
                                                       FontSize="24"
                                                       Foreground="Wheat" Margin="0,-1,0,-1"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Heart" Property="Foreground" Value="RosyBrown"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="Heart" Property="Foreground" Value="Wheat"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                </ScrollViewer>
                <Grid Width="300" Height="650" VerticalAlignment="Bottom" HorizontalAlignment="Right">
                    <Border Height="50" Width="300" HorizontalAlignment="Right" VerticalAlignment="Top"
                            CornerRadius="10 0 0 10" Background="#FF1E3A8A">
                        <Grid x:Name="search" HorizontalAlignment="Center" Width="200">
                            <Button x:Name="btnPoisk" Height="40" Width="40" HorizontalAlignment="Left"
                                    Background="Transparent">

                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                Width="300" Height="600">
                        <Border Background="#FF0B1F5E" Width="300" Height="600" Margin="0 10 0 0">
                            <Grid>
                                <Grid Grid.Column="0" Height="150" VerticalAlignment="top" Margin="0 10 0 0">
                                    <Grid x:Name="slides">
                                        <Border x:Name="slide1" Width="200" CornerRadius="20" Background="red"/>
                                        <Border x:Name="slide2" Width="200" CornerRadius="20" Background="Green" Visibility="Collapsed"/>
                                        <Border x:Name="slide3" Width="200" CornerRadius="20" Background="Blue" Visibility="Collapsed"/>
                                    </Grid>

                                    <Button Content="←" Background="Transparent" Foreground="White"
                                            Width="50" Height="50" FontWeight="Bold" FontSize="20"
                                            HorizontalAlignment="Left"
                                            VerticalAlignment="Center"
                                            Click="Left_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <Button Content="→" Background="Transparent" Foreground="White"
                                            Width="50" Height="50" FontWeight="Bold" FontSize="20"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"
                                            Click="Right_click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                                     CornerRadius="5">
                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                </Border>

                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </Grid>

                                <StackPanel Height="300" Margin="0 50 0 0">
                                    <TextBlock Text="Новости" FontFamily="Century Gothic" FontWeight="ExtraLight"
                                               TextWrapping="Wrap" FontSize="20" VerticalAlignment="Center"
                                               Foreground="White"/>
                                    <StackPanel x:Name="News" Height="130"/>

                                    <TextBlock Text="Обсуждение" FontFamily="Century Gothic" FontWeight="ExtraLight"
                                               TextWrapping="Wrap" FontSize="20" VerticalAlignment="Center"
                                               Foreground="White"/>
                                    <ScrollViewer Height="130">
                                        <StackPanel x:Name="Corns"/>
                                    </ScrollViewer>

                                </StackPanel>
                                <Button x:Name="btnDarkMode"
                                        Width="50" Height="40"
                                        HorizontalAlignment="Right"
                                        VerticalAlignment="Bottom"
                                        Margin="0 0 10 10"
                                        Background="#FFC6C6C6" Click="btnDarkMode_Click">
                                    <Image Source="/View/img/photo_5363890893003364313_m-Photoroom.png"
                                           Width="30" Height="30"/>

                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                     CornerRadius="5">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>

                    </StackPanel>
                    <TextBox x:Name="Poisk" HorizontalAlignment="Right" VerticalAlignment="Top"
                                   Width="235"  Height="30" FontSize="15" FontFamily="Century Gothic" TextChanged="Poisk_TextChanged_1" Margin="0,10,5,0" />
                    <Image Source="/View/img/a77e71b6097a21ddac693bdb7c8dff23.jpg"
                                       Margin="10,5,250,605"/>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
