<Window x:Class="prac.View.inter.maga"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:prac.View.inter"
        mc:Ignorable="d"
        Title="intr" Height="750" Width="1200"
        WindowStyle="None" WindowStartupLocation="CenterScreen"
         Background="Transparent">

    <Window.Resources>
        <Style x:Key="trigBth" TargetType="Button" >
            <Setter Property="Background" Value="#88eaf7"/>
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="Padding" Value="10,5"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="3"
                                Width="300" Height="50">
                            <ContentPresenter HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Margin="10,0,0,0"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="Blue"/>
                                <Setter Property="Cursor" Value="Hand"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Grid.Column="0"
                    Background="#88eaf7"
                    CornerRadius="20,0,0,20">
                <StackPanel>
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border x:Name="Ava" Width="100" Height="100" 
                                        Background="White"
                                        CornerRadius="100"/>
                        <StackPanel Grid.Column="1"
                                            Margin="10,0,0,0"
                                            VerticalAlignment="Center">

                            <TextBlock Text="{Binding UserNek}" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"
                                               Foreground="White"/>
                            <TextBlock Text="{Binding UserName}" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" TextWrapping="Wrap" FontSize="20"
                                               Foreground="White"/>

                        </StackPanel>
                    </Grid>
                    <Button Style="{StaticResource trigBth}"
                                    x:Name="Shop"
                                    FontFamily="Century Gothic"
                                    FontSize="16" Background="#64b2bd"
                                    HorizontalAlignment="Left"
                                    Margin="0 80 0 0" Click="maga_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/telega2.jpg"
                                   Width="30" Height="30"
                                   Margin="10,0,10,0"/>
                            <TextBlock Text="Магазин" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource trigBth}"
                             x:Name="dok"
                             FontFamily="Century Gothic"
                             FontSize="16"
                             HorizontalAlignment="Left"
                             Margin="0 0 0 0" Click="bymaga_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/nomen.jpg"
                                   Width="30" Height="30"
                                   HorizontalAlignment="Left"
                                   Margin="10,0,10,0" />
                            <TextBlock Text="Номеклатура" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource trigBth}"
                            x:Name="Game"
                            FontFamily="Century Gothic"
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 0" Click="game_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/gamepade.png"
                                    Width="30" Height="30"
                                    HorizontalAlignment="Left"
                                    Margin="10,0,10,0" />
                            <TextBlock Text="Игры" FontFamily="Century Gothic"
                                       FontWeight="ExtraLight" TextWrapping="Wrap"
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource trigBth}"
                            x:Name="Set"
                            FontFamily="Century Gothic"
                            FontSize="16"
                            HorizontalAlignment="Left"
                            Margin="0 0 0 0" Click="set_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/set2.jpg"
                                    Width="30" Height="30"
                                    Margin="10,0,10,0" />
                            <TextBlock Text="Настройки аккаунта" FontFamily="Century Gothic"
                                   FontWeight="ExtraLight" TextWrapping="Wrap"
                                   FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource trigBth}" 
                                x:Name="bthBask" 
                                FontFamily="Century Gothic" 
                                FontSize="16" 
                                HorizontalAlignment="Left" 
                                Margin="0 0 0 0" Click="bthBask_Click">

                        <StackPanel Orientation="Horizontal">
                            <Image Source="/View/img/corzina.jpg" 
                                       Width="30" Height="30" 
                                       Margin="10 0 10 0"/>
                            <TextBlock Text="Корзина" FontFamily="Century Gothic"  
                                       FontWeight="ExtraLight" TextWrapping="Wrap" 
                                       FontSize="20" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>

            </Border>
            <Grid Grid.Column="1">
                <Grid HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="-" FontSize="20"
                            Width="30" Margin="5,5,5,5"
                            Background="LightBlue" Foreground="White"
                            Click="btnMin_click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="1" Content="0" FontSize="20"
                            Width="30" Height="30" Margin="5"
                            Background="DarkGoldenrod" Foreground="White"
                            Click="btnMax_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Button Grid.Column="2" Content="X" FontSize="20"
                            Width="30" Height="30" Margin="5,5,5,0"
                            Background="#FF9D140A" Foreground="White"
                            Click="btnClose_click" VerticalAlignment="Top">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        BorderThickness="0">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </Grid>


                <ScrollViewer Width="600" HorizontalAlignment="Left" Background="Gray">
                    <WrapPanel Width="Auto">
                        <Border Background="White" Width="150" Height="200"
                                       Margin="10 50 0 0" CornerRadius="10">
                            <StackPanel>
                                <Border x:Name="IMG1" Width="130" Height="130" Background="Gray"
                                    CornerRadius="10" HorizontalAlignment="Center"
                                    Margin="0 10 0 0" VerticalAlignment="Top"/>

                                <TextBlock Text="Текст" FontFamily="Century Gothic"
                                                  FontWeight="ExtraLight" TextWrapping="Wrap"
                                                  FontSize="15"/>
                                <ToggleButton Width="94" Height="30"
                                                     Background="Transparent"
                                                     BorderThickness="0" Checked="LikeButton_Cheched">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border Background="Blue" CornerRadius="5">
                                                <TextBlock x:Name="Heart" HorizontalAlignment="Center"
                                                       Text="Купить"
                                                       FontSize="24"
                                                       Foreground="Wheat" Margin="0,-1,0,-1"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Heart" Property="Foreground" Value="RosyBrown"/>
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="False">
                                                    <Setter TargetName="Heart" Property="Foreground" Value="Wheat"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </StackPanel>
                        </Border>

                    </WrapPanel>

                </ScrollViewer>
                <Grid Width="300" Height="58" VerticalAlignment="Bottom" HorizontalAlignment="Right" Margin="0,0,0,592">
                    <Border Height="48" Width="300" HorizontalAlignment="Center" VerticalAlignment="Top"
                            CornerRadius="10 0 0 10" Background="#88eaf7">
                        <Grid x:Name="search" HorizontalAlignment="Center" Width="200">

                            <TextBox x:Name="Poisk" VerticalAlignment="Center"  Height="30" FontSize="15" FontFamily="Century Gothic" Margin="0,0,-31,0"  />
                        </Grid>
                    </Border>
                    <Image Source="/View/img/lypa.jpg"
                                       Margin="10,5,252,16"/>
                    <Button x:Name="btnPoisk" Height="40" Width="40" HorizontalAlignment="Left"
                                    Background="Transparent" Margin="10,5,0,605" Click="btnPoisk_Click">

                        <Button.Template>
                            <ControlTemplate TargetType="{x:Type Button}">
                                <Border Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <Grid Width="300" HorizontalAlignment="Center" Margin="0,80,0,-590">
                        <TabControl Margin="0">
                            <TabItem Header="Фильтры">
                                <Grid Background="Gray">
                                    <StackPanel Background="#88eaf7">
                                        <TextBlock Text="Фильтры" FontFamily="Century Gothic"
                                               FontWeight="ExtraLight" Foreground="White" 
                                               FontSize="20" VerticalAlignment="Center" />
                                        <Button Width="200" Height="25" Margin="0 10 0 0" Content="Кейсы"
                                            Foreground="Black" FontSize="15" Click="Button_Click"/>
                                        <Button Width="200" Height="25" Margin="0 10 0 0" Content="Скины"
                                            Foreground="Black" FontSize="15" Click="Button_Click_1"/>
                                        <Button Width="200" Height="25" Margin="0 10 0 0" Content="Предметы"
                                            Foreground="Black" FontSize="15" Click="Button_Click_2"/>
                                        <Button Width="200" Height="25" Margin="0 10 0 0" Content="Обл. персонажа"
                                            Foreground="Black" FontSize="15" Click="Button_Click_3"/>
                                        <Button Width="200" Height="25" Margin="0 10 0 0" Content="Игровая валюта"
                                            Foreground="Black" FontSize="15" Click="Button_Click_4"/>

                                    </StackPanel>
                                </Grid>
                            </TabItem>
                            <TabItem Header="Другое">
                                <Grid Background="#88eaf7">
                                    <StackPanel >
                                        <Border Background="#88eaf7" Width="300" Height="530" Margin="0 10 0 0">
                                            <Grid>
                                                <Grid Grid.Column="0" Height="150" VerticalAlignment="top" Margin="0 10 0 0">
                                                    <Grid x:Name="slides">
                                                        <Border x:Name="slide1" Width="200" CornerRadius="20" Background="red"/>
                                                        <Border x:Name="slide2" Width="200" CornerRadius="20" Background="Green" Visibility="Collapsed"/>
                                                        <Border x:Name="slide3" Width="200" CornerRadius="20" Background="Blue" Visibility="Collapsed"/>
                                                    </Grid>

                                                    <Button Content="←" Background="Transparent" Foreground="Black"
                                                            Width="50" Height="50" FontWeight="Bold" FontSize="20"
                                                            HorizontalAlignment="Left"
                                                            VerticalAlignment="Center"
                                                            Click="Left_Click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                        CornerRadius="5">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                      VerticalAlignment="Center"/>
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                    <Button Content="→" Background="Transparent" Foreground="Black"
                                                            Width="50" Height="50" FontWeight="Bold" FontSize="20"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Click="Right_click">
                                                        <Button.Template>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border Background="{TemplateBinding Background}"
                                                                                     CornerRadius="5">
                                                                    <ContentPresenter HorizontalAlignment="Center"
                                                                                                      VerticalAlignment="Center"/>
                                                                </Border>

                                                            </ControlTemplate>
                                                        </Button.Template>
                                                    </Button>

                                                </Grid>

                                                <StackPanel Height="300" Margin="0 100 0 0">
                                                    <TextBlock Text="Новости" FontFamily="Century Gothic" FontWeight="ExtraLight"
                                                               TextWrapping="Wrap" FontSize="20" VerticalAlignment="Center"
                                                               Foreground="Black"/>
                                                    <StackPanel x:Name="News" Height="130"/>

                                                    <TextBlock Text="Обсуждение" FontFamily="Century Gothic" FontWeight="ExtraLight"
                                                               TextWrapping="Wrap" FontSize="20" VerticalAlignment="Center"
                                                               Foreground="Black"/>
                                                    <ScrollViewer Height="130">
                                                        <StackPanel x:Name="Corns"/>
                                                    </ScrollViewer>

                                                </StackPanel>
                                                <Button x:Name="btnDarkMode"
                                                        Width="50" Height="40"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Bottom"
                                                        Margin="0 0 10 10"
                                                        Background="#FFC6C6C6" Click="btnDarkMode_Click">
                                                    <Image Source="/View/img/photo_5363890893003364313_m-Photoroom.png"
                                                           Width="30" Height="30"/>

                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}"
                                                                     CornerRadius="5">
                                                                <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </Grid>
                                        </Border>

                                    </StackPanel>
                                </Grid>
                            </TabItem>
                        </TabControl>

                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
