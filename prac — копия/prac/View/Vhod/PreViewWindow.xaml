<Window x:Class="prac.Vhod.PreViewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:prac.Vhod"
        mc:Ignorable="d"
        Title="Добро пожаловать" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

    <Grid>
        
        <MediaElement
                      Source="View/vid/687648ad7a097a7017204cd08bc9d028.mp4"
                      LoadedBehavior="Play"
                      Stretch="Fill"
                      IsMuted="False"
                      MediaEnded="VideoPlayer_MediaEnded"/>

        
        <TextBlock Text="Добро пожаловать!"
                   FontSize="56"
                   FontWeight="Bold"
                   FontFamily="Times New Roman"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center" Foreground="Red">
            <TextBlock.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="4" Opacity="0.8"/>
            </TextBlock.Effect>
        </TextBlock>

    </Grid>
</Window>