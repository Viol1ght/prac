<Window x:Class="prac.View.Vhod.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:prac.View.Vhod"
        mc:Ignorable="d"
        Title="Восстановление пароля" Height="500" Width="650"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Grid>
        <!-- Слой 1: Фон (самый нижний) -->
        <Image Source="/View/img/df69947c204279ca5b3ccafe74f6a0c7.jpg" 
               Stretch="UniformToFill" 
               Opacity="1"/>

        <!-- Слой 2: Подложка -->
        <Border Background="#80708090" 
                CornerRadius="20" 
                Margin="20"/>

        <!-- Слой 3: Основной контент -->
        <Grid Margin="20">
            <!-- Форма восстановления -->
            <Border Height="430" Width="580" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Background="#708090" 
                    CornerRadius="30"
                    Opacity="0.95">
                <Grid>
                    <StackPanel>
                        <TextBlock FontFamily="Times New Roman"
                                   FontSize="32" HorizontalAlignment="Center" Margin="0,40,0,20">
                            <Run Language="ru-ru" Text="Введите ник и логин"/>
                        </TextBlock>

                        <!-- Поле Ник с глазиком -->
                        <TextBlock FontFamily="Times New Roman"
                                   FontSize="20" Margin="70,10,0,0">
                            <Run Language="ru-ru" Text="Ник"/>
                        </TextBlock>
                        <Grid Margin="70,5,70,0" Width="440" Height="40" HorizontalAlignment="Left">
                            <TextBox x:Name="Login" 
                                     FontSize="18" 
                                     Width="440" 
                                     Height="40" 
                                     Padding="8,0,35,0"
                                     VerticalAlignment="Center"/>
                           
                        </Grid>

                        <!-- Поле Логин с глазиком -->
                        <TextBlock FontFamily="Times New Roman"
                                   FontSize="20" Margin="70,15,0,0">
                            <Run Language="ru-ru" Text="Логин"/>
                        </TextBlock>
                        <Grid Margin="70,5,70,0" Width="440" Height="40" HorizontalAlignment="Left">
                            <TextBox x:Name="Nickname" 
                                     FontSize="18" 
                                     Width="440" 
                                     Height="40" 
                                     Padding="8,0,35,0"
                                     VerticalAlignment="Center"/>
                            <Button x:Name="EyeButtonNickname" 
                                    Width="30" Height="30" 
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="EyeButtonNickname_Click">
                                <Image x:Name="EyeImageNickname" 
                                       Source="/View/img/hide.png" 
                                       Width="20" Height="20"/>
                            </Button>
                        </Grid>

                        <Button x:Name="RestoreButton" Content="Найти пользователя"
                                FontFamily="Times New Roman" FontSize="20"
                                HorizontalAlignment="Center" Margin="0,30,0,20"
                                Background="#FF1B2FB2" Foreground="White"
                                Width="280" Height="55" Click="RestoreButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    <!-- Кнопка назад внутри формы -->
                    <Button x:Name="BackButton" Content="←"
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Top"
                            Width="45" Height="45" 
                            FontSize="28" FontWeight="Bold"
                            Margin="19,24,0,0"
                            Background="#CCCCCC" 
                            Foreground="Black"
                            Click="BackToLogin_Click"
                            Panel.ZIndex="100">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        <!-- Кнопки управления окном (Min, Max, Close) - на переднем плане -->
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Margin="0,35,35,0"
                    Panel.ZIndex="200">
            <Button x:Name="btnMin" Content="─"
                    Width="35" Height="35" 
                    Background="#FF567FCB"
                    Foreground="White"
                    Click="btnMin_Click"/>
            <Button x:Name="btnMax" Content="□"
                    Width="35" Height="35" Margin="5,0,0,0"
                    Background="DarkGoldenrod"
                    Foreground="White"
                    Click="btnMax_Click"/>
            <Button x:Name="btnClose" Content="X"
                    Width="35" Height="35" Margin="5,0,0,0"
                    Background="#FF9D14DA"
                    Foreground="White"
                    Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>