<Window x:Class="prac.View.Vhod.RegistrationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:prac.View.Vhod"
        mc:Ignorable="d"
        Title="Регистрация" Height="650" Width="750"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        Background="Transparent"
        AllowsTransparency="True">

    <Grid>
        
        <Image Source="/View/img/df69947c204279ca5b3ccafe74f6a0c7.jpg" 
               Stretch="UniformToFill" 
               Opacity="1"/>

        
        <Border Background="#80708090" 
                CornerRadius="20" 
                Margin="20"/>

        
        <Grid Margin="20">
            
            <Border Height="580" Width="700" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center"
                    Background="#708090" 
                    CornerRadius="30"
                    Opacity="0.95">
                <Grid>
                    
                    <Border Width="140" Height="140" CornerRadius="70" 
                            HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,25,0,0"
                            Background="LightGray" BorderBrush="Gray" BorderThickness="2">
                        <Grid>
                            <Image x:Name="UserImage" Stretch="UniformToFill"/>
                            <Button Content="+" HorizontalAlignment="Center" VerticalAlignment="Center"
                                    Width="45" Height="45" FontSize="28" FontWeight="Bold"
                                    Background="#CCFFFFFF" Foreground="Black" Click="LoadPhoto_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="22"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>

                    <StackPanel Margin="0,180,0,0">
                        <TextBlock Text="Регистрация" FontFamily="Times New Roman"
                                   FontSize="36" HorizontalAlignment="Center" Margin="0,0,0,25"/>

                        <TextBlock Text="Логин" FontFamily="Times New Roman"
                                   FontSize="22" HorizontalAlignment="Left" Margin="100,5,0,0"/>
                        <TextBox x:Name="Login" FontSize="18" Width="450" Height="40" 
                                 Margin="100,5,0,0" Padding="8"/>

                        <TextBlock Text="Ник" FontFamily="Times New Roman"
                                   FontSize="22" HorizontalAlignment="Left" Margin="100,15,0,0"/>
                        <TextBox x:Name="Nickname" FontSize="18" Width="450" Height="40" 
                                 Margin="100,5,0,0" Padding="8"/>

                        
                        <TextBlock Text="Пароль" FontFamily="Times New Roman"
                                   FontSize="22" HorizontalAlignment="Left" Margin="100,15,0,0"/>

                        <Grid Margin="100,5,0,0" Width="450" Height="40">
                            
                            <PasswordBox x:Name="Pass" 
                                         FontSize="18" 
                                         Width="450" 
                                         Height="40" 
                                         Padding="8,0,35,0"
                                         VerticalAlignment="Center"/>

                            
                            <TextBox x:Name="PassText" 
                                     FontSize="18" 
                                     Width="450" 
                                     Height="40" 
                                     Padding="8,0,35,0"
                                     Visibility="Collapsed"
                                     VerticalAlignment="Center"
                                     TextChanged="PassText_TextChanged"/>

                            
                            <Button x:Name="TogglePasswordButton" 
                                    Width="30" Height="30" 
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0"
                                    Background="Transparent" 
                                    BorderThickness="0"
                                    Cursor="Hand"
                                    Click="TogglePasswordButton_Click">
                                <Image x:Name="EyeIcon" 
                                       Source="/View/img/hide.png" 
                                       Width="20" Height="20"/>
                            </Button>
                        </Grid>

                        <Button x:Name="RegisterButton" Content="Зарегистрироваться"
                                FontFamily="Times New Roman" FontSize="22"
                                HorizontalAlignment="Center" Margin="0,35,0,0"
                                Background="#FF1B2FB2" Foreground="White"
                                Width="280" Height="55" Click="RegisterButton_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="15"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>

                    
                    <Button x:Name="BackButton" Content="←"
                            HorizontalAlignment="Left" 
                            VerticalAlignment="Top"
                            Width="45" Height="45" 
                            FontSize="28" FontWeight="Bold"
                            Margin="19,24,0,0"
                            Background="#CCCCCC" 
                            Foreground="Black"
                            Click="BackToLogin_Click"
                            Panel.ZIndex="100">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Border>
        </Grid>

        
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Margin="0,35,35,0"
                    Panel.ZIndex="200">
            <Button x:Name="btnMin" Content="─"
                    Width="35" Height="35" 
                    Background="#FF567FCB"
                    Foreground="White"
                    Click="btnMin_Click"/>
            <Button x:Name="btnMax" Content="□"
                    Width="35" Height="35" Margin="5,0,0,0"
                    Background="DarkGoldenrod"
                    Foreground="White"
                    Click="btnMax_Click"/>
            <Button x:Name="btnClose" Content="X"
                    Width="35" Height="35" Margin="5,0,0,0"
                    Background="#FF9D14DA"
                    Foreground="White"
                    Click="btnClose_Click"/>
        </StackPanel>
    </Grid>
</Window>